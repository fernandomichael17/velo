# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://velo_user:velo_password@localhost:5432/velo_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=ganti-dengan-random-string-minimal-32-karakter
BETTER_AUTH_URL=http://localhost:3001

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=velo-uploads

# Email (Resend) — isi nanti saat Fase 3
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# OAuth Google — isi nanti
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:3000